#!/bin/bash
# EDAO-NMS Onboarding Tool .app — URL-scheme bridge.
# macOS routes edaonms-proxy-onboard:// here; we just delegate to the
# canonical launch_mac.command sitting alongside this .app bundle.

# Resolve the directory containing the .app (3 levels up from MacOS/).
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
LAUNCHER="$APP_DIR/launch_mac.command"

if [ ! -x "$LAUNCHER" ]; then
    osascript -e "display alert \"EDAO-NMS Onboarding Tool\" message \"launch_mac.command was not found next to the app bundle.\n\nExpected: $LAUNCHER\n\nKeep the .app inside the edao-nms-onboarding-tool folder.\" as critical"
    exit 1
fi

# Replace the .app's process with the launcher (which itself execs
# python3). This keeps the .app's PID alive for the lifetime of the
# Tk window — if we backgrounded + exited here, macOS would reap the
# child process group when the .app exited and the tool would never
# get a chance to draw its window (silent failure with no output).
exec "$LAUNCHER"
